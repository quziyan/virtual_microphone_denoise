#!/bin/bash
# Runs as root during .pkg install. Installs the BlackHole virtual audio driver
# (bundled alongside this script) and restarts CoreAudio so it loads immediately.
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
HAL="/Library/Audio/Plug-Ins/HAL"
DRIVER="$HAL/BlackHole2ch.driver"

mkdir -p "$HAL"

# Install BlackHole only if it isn't already present (don't clobber a user's copy).
if [ ! -d "$DRIVER" ] && [ -f "$SCRIPT_DIR/BlackHole2ch.driver.tar" ]; then
    tar -xf "$SCRIPT_DIR/BlackHole2ch.driver.tar" -C "$HAL"
    chown -R root:wheel "$DRIVER"
    chmod -R 755 "$DRIVER"
fi

# Clear quarantine on the freshly installed app so it opens without extra prompts.
if [ -d "/Applications/VibeCodingVirMic.app" ]; then
    xattr -dr com.apple.quarantine "/Applications/VibeCodingVirMic.app" 2>/dev/null || true
    # (Re)register exactly this bundle with LaunchServices so Launchpad/Spotlight
    # point at the single /Applications copy and don't surface stale duplicates.
    LSREGISTER="/System/Library/Frameworks/CoreServices.framework/Versions/A/Frameworks/LaunchServices.framework/Versions/A/Support/lsregister"
    [ -x "$LSREGISTER" ] && "$LSREGISTER" -f "/Applications/VibeCodingVirMic.app" 2>/dev/null || true
fi

# Restart CoreAudio so the new driver shows up as a device right away.
killall coreaudiod 2>/dev/null || true

# If preinstall killed a running instance, relaunch the NEW build in the logged-in
# user's GUI session (root must hop into the user's session via launchctl asuser).
FLAG="/tmp/.vmic_was_running"
if [ -f "$FLAG" ] && [ -d "/Applications/VibeCodingVirMic.app" ]; then
    CONSOLE_USER="$(stat -f%Su /dev/console 2>/dev/null)"
    if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ]; then
        CONSOLE_UID="$(id -u "$CONSOLE_USER")"
        launchctl asuser "$CONSOLE_UID" \
            open -a "/Applications/VibeCodingVirMic.app" 2>/dev/null || true
    fi
fi
rm -f "$FLAG"

exit 0
